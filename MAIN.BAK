#include <iostream.h>
#include <conio.h>

struct coordinate
{
	int x, y;
};
coordinate boundary1 = {1, 1}, boundary2 = {79, 23};
void genCh(coordinate p, char c)
{
	gotoxy(p.x, p.y);
	cout << c;
}

int main()
{
	coordinate pos = {41, 12};
    clrscr();
    char ch, player;
    do
    {
	ch = getch();
	switch (ch)
	{
		case 'w':
			player = '^';
			if (pos.y > boundary1.y) pos.y--;
			break;
		case 'a':
			player = '<';
			if (pos.x > boundary1.x) pos.x -= 2;
			break;
		case 's':
			player = 'v';
			if (pos.y < boundary2.y) pos.y++;
			break;
		case 'd':
			player = '>';
			if (pos.x < boundary2.x) pos.x += 2;
			break;

	}

	cout << "\b ";
	genCh(pos, player);
    } while (ch != 'q');

    return 0;
}