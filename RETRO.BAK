#include <iostream.h>
#include <fstream.h>
#include <string.h>
#include "utils.h"

struct coordinate
{
	short x, y;
};

enum face {UP, LEFT, RIGHT, DOWN};

struct state
{
    coordinate pos;
    short hp, status, facing;
};
state loadState();
class Player;
class Retro
{
    private:
        coordinate boundary1, boundary2;
        state currentState;

        void displayUI()
        {
            drawBox(1, 1, 79, 24);
            vertLine(1, 24, 67);
            genCh(67, 1, 203);
            genCh(67, 24, 202);
            genSen(68, 2, "Retro-Bound");
            gotoxy(68, 3);
            for(int i = 0; i < 11; i++) cout << (char)196;
        }

    public:
        Retro()
        {
            boundary1.x = 2; boundary1.y = 2;
            boundary2.x = 66; boundary2.y = 23;
            currentState = loadState(); 
        }

        void updatePlayer(Player p)
        {
            char ch;
            switch(facing)
            {
                case UP:
                    ch = '^'
            }

        }
        void run()
        {
            clrscr();
            displayUI();
        }
        
};

class Player
{
    coordinate pos;
    short hp, facing;

    public:
        Player(state s)
        {
            pos.x = s.pos.x;
            pos.y = s.pos.y;
            hp = s.hp;
            facing = s.facing;
        }

        friend Retro :: updatePlayer(Player);
};


// Movement function

state loadState()
{
    // default
    state temp;
    
    ifstream f("save.dat");
    if (f)
    {
        f >> temp.pos.x >> temp.pos.y;
        f.close();
    }

    return pos;
}
void saveState(coordinate pos)
{
    ofstream f("save.dat");
    if (f)
    {
        f << pos.x << "\n" << pos.y;
        f.close();
    }
}